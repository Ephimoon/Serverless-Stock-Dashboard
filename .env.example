# Stock data API key used for local development only
# The deployed AWS Lambdas use AWS Secrets Manager instead
STOCK_API_KEY=your_stock_api_key_here

# DynamoDB table name
TABLE_NAME=stock_movers

# AWS config for local CDK commands
AWS_REGION=us-east-1
AWS_PROFILE=default

# Secret name created or referenced by AWS CDK
SECRET_NAME=stock-dashboard/api-key